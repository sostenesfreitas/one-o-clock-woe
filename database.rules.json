      "rates": {
        "card": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "illusion": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "white": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "black": { ".validate": "newData.isNumber() && newData.val() >= 1" }
      }
    },

    "auction_overrun": {
