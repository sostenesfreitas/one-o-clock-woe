{
  "rules": {
    ".read": false,
    ".write": false,

    "members": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)",
      "$mid": {
        ".write": "auth != null && data.exists() && newData.exists()",
        "name":           { ".validate": "newData.isString() && newData.val().length <= 64", "$x": { ".validate": false } },
        "job":            { ".validate": "newData.isString() && newData.val().length <= 64", "$x": { ".validate": false } },
        "discord":        { ".validate": "newData.isString() && newData.val().length <= 64", "$x": { ".validate": false } },
        "discordId":      { ".validate": "newData.isString() && newData.val().length <= 32", "$x": { ".validate": false } },
        "cp":             { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100000000", "$x": { ".validate": false } },
        "updatedAt":      { ".validate": "newData.isNumber()", "$x": { ".validate": false } },
        "updatedBy":      { ".validate": "newData.isString() && newData.val().length <= 64", "$x": { ".validate": false } },
        "onLeaveLeague":  { ".validate": "newData.isBoolean()", "$x": { ".validate": false } },
        "onLeaveOverrun": { ".validate": "newData.isBoolean()", "$x": { ".validate": false } },
        "$other":         { ".validate": false }
      }
    },

    "parties": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "auction_gl": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)",
      "rates": {
        "card": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "illusion": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "white": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "black": { ".validate": "newData.isNumber() && newData.val() >= 1" }
      }
    },

    "auction_overrun": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)",
      "rates": {
        "card": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "illusion": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "white": { ".validate": "newData.isNumber() && newData.val() >= 1" },
        "black": { ".validate": "newData.isNumber() && newData.val() >= 1" }
      }
    },

    "auction_requests": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)",
      "$date": {
        "$mode": {
          "$reqId": {
            ".write": "auth != null && ((!data.exists() && newData.exists()) || (data.exists() && !newData.exists()))",
            ".validate": "!newData.exists() || newData.hasChildren(['memberId', 'status'])"
          }
        }
      }
    },

    "leaves": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)",
      "$mid": {
        "$date": {
          ".write": "auth != null",
          ".validate": "!newData.exists() || newData.isBoolean()"
        }
      }
    },

    "job_targets": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "markers": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "markers_bottom": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "overrun_markers": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "range_circles": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "system": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "admins": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

    "users": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    }
  }
}
