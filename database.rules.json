{
  "rules": {
    ".read": false,
    ".write": false,

    "members": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)",
      "$mid": {
        ".write": "auth != null && data.exists() && newData.exists()"
      }
    },

    "parties": {
      ".read": "auth != null",
      ".write": "auth != null && auth.token.email != null && (auth.token.email.toLowerCase() == 'blankkardor@gmail.com' || root.child('admins').child(auth.token.email.toLowerCase().replace('.', '_')).val() == true)"
    },

